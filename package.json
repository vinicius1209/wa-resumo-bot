{
  "name": "wa-resumo-bot",
  "version": "1.0.0",
  "description": "Bot de WhatsApp que monitora conversas e gera resumos fiéis usando LLMs (OpenAI/Anthropic). Inclui quiz, retro, dívidas, sentimento e dashboard admin.",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run dashboard:build && tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "nodemon --exec ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "setup": "node scripts/setup.mjs",
    "dashboard:dev": "cd dashboard-ui && npm run dev",
    "dashboard:build": "cd dashboard-ui && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinicius1209/wa-resumo-bot.git"
  },
  "homepage": "https://github.com/vinicius1209/wa-resumo-bot#readme",
  "bugs": {
    "url": "https://github.com/vinicius1209/wa-resumo-bot/issues"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "resumo",
    "summary",
    "llm",
    "openai",
    "anthropic",
    "baileys",
    "chatbot",
    "dashboard"
  ],
  "author": "Vinícius Machado",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@whiskeysockets/baileys": "^6.7.16",
    "better-sqlite3": "^11.6.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.2",
    "openai": "^4.73.0",
    "pino": "^9.5.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
