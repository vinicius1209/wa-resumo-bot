# ============================================
# WA-RESUMO-BOT — Configuração
# ============================================
# Copie este arquivo para .env e preencha os valores

# --- LLM Provider ---
# Qual provider usar: "openai" | "anthropic"
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Resumo ---
# Número máximo de mensagens para incluir no resumo
SUMMARY_MAX_MESSAGES=200

# Idioma padrão do resumo
SUMMARY_LANGUAGE=pt-BR

# --- Bot ---
# Nome do bot (usado para detectar menções)
BOT_NAME=ResumoBot

# Prefixo de comando
COMMAND_PREFIX=/

# --- Rate Limit ---
# Máximo de comandos LLM por janela (por grupo)
RATE_LIMIT_MAX_REQUESTS=3

# Janela de tempo em segundos
RATE_LIMIT_WINDOW_SECONDS=300

# --- Mídia ---
# Habilitar processamento de mídia (visão + transcrição)
MEDIA_PROCESSING_ENABLED=true

# Tamanho máximo de mídia para processar (em MB)
MEDIA_MAX_SIZE_MB=20

# --- Dashboard ---
# Habilitar o dashboard admin
DASHBOARD_ENABLED=true

# Porta do dashboard
DASHBOARD_PORT=3000

# Token de autenticação (troque por um valor seguro!)
DASHBOARD_TOKEN=change-me

# --- Palavra do Dia ---
# Enviar automaticamente às 23h nos grupos ativos (respeita allowlist + feature toggle)
WORD_OF_DAY_AUTO=false

# --- Modo Conversacional ---
# Habilitar conversas multi-turn via @menção (sem comando)
CONVERSATION_ENABLED=false

# Máximo de turns por sessão
CONVERSATION_MAX_TURNS=20

# Tempo de expiração da sessão em minutos
CONVERSATION_SESSION_TTL_MINUTES=30

# Habilitar conversas via DM (mensagens diretas)
CONVERSATION_DM_ENABLED=false

# Temperatura do LLM para conversas (0.0-1.0, mais alto = mais criativo)
CONVERSATION_TEMPERATURE=0.7

# Máximo de tokens por resposta conversacional
CONVERSATION_MAX_TOKENS=1000

# --- Sentimento / Treta ---
# Habilitar auto-provocação (bot manda zoeira quando grupo esquenta)
SENTIMENT_AUTO_REACT=false

# --- Podcast (resumo em áudio) ---
# Habilitar geração de podcast via /podcast
PODCAST_ENABLED=false

# Provider TTS: "gemini" | "openai"
TTS_PROVIDER=gemini

# API key do Google AI (para Gemini TTS)
GOOGLE_TTS_API_KEY=

# Modelo Gemini TTS
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Vozes dos apresentadores (ver: https://ai.google.dev/gemini-api/docs/speech-generation)
PODCAST_HOST1_VOICE=Kore
PODCAST_HOST2_VOICE=Puck

# Duração máxima do podcast em minutos
PODCAST_MAX_DURATION_MINUTES=5

# --- Logging ---
# Nível de log: "silent" | "fatal" | "error" | "warn" | "info" | "debug" | "trace"
LOG_LEVEL=info
