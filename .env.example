# ============================================
# WA-RESUMO-BOT — Configuração
# ============================================
# Copie este arquivo para .env e preencha os valores

# --- LLM Provider ---
# Qual provider usar: "openai" | "anthropic"
LLM_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Resumo ---
# Número máximo de mensagens para incluir no resumo
SUMMARY_MAX_MESSAGES=200

# Idioma padrão do resumo
SUMMARY_LANGUAGE=pt-BR

# --- Bot ---
# Nome do bot (usado para detectar menções)
BOT_NAME=ResumoBot

# Prefixo de comando
COMMAND_PREFIX=/

# --- Mídia ---
# Habilitar processamento de mídia (visão + transcrição)
MEDIA_PROCESSING_ENABLED=true

# Tamanho máximo de mídia para processar (em MB)
MEDIA_MAX_SIZE_MB=20

# --- Dashboard ---
# Habilitar o dashboard admin
DASHBOARD_ENABLED=true

# Porta do dashboard
DASHBOARD_PORT=3000

# Token de autenticação (troque por um valor seguro!)
DASHBOARD_TOKEN=change-me

# --- Logging ---
# Nível de log: "silent" | "fatal" | "error" | "warn" | "info" | "debug" | "trace"
LOG_LEVEL=info
